services:
  sglang-gateway:
    image: lmsysorg/sgl-model-gateway:latest
    container_name: sglang-gateway
    restart: unless-stopped

    command:
      - --host
      - 0.0.0.0
      - --port
      - "{{ sglang_gateway_port }}"
      - --policy
      - "{{ sglang_gateway_policy }}"
      - --worker-urls
{% for url in sglang_gateway_worker_urls %}
      - "{{ url }}"
{% endfor %}

    ports:
      - "127.0.0.1:{{ sglang_gateway_port }}:{{ sglang_gateway_port }}"
  forgejo:
    image: codeberg.org/forgejo/forgejo:15
    container_name: forgejo
    restart: unless-stopped

    environment:
      USER_UID: "1000"
      USER_GID: "1000"

      FORGEJO__server__DOMAIN: "{{ caddy_hostname }}"
      FORGEJO__server__ROOT_URL: "https://{{ caddy_hostname }}/"
      FORGEJO__server__HTTP_PORT: "3000"
      FORGEJO__server__SSH_DOMAIN: "{{ caddy_hostname }}"
      FORGEJO__server__SSH_PORT: "2222"

      FORGEJO__database__DB_TYPE: "sqlite3"

    ports:
      - "127.0.0.1:3000:3000"
      - "2222:22"

    volumes:
      - "{{ data_mount }}/forgejo/data:/data"
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
